{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Archivist Manifest Schema",
  "type": "object",
  "properties": {
    "manifest_id": { "type": "string" },
    "project_id": { "type": "string" },
    "pipeline_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "target_repo": { "type": "string" },
          "requires": { 
            "type": "array",
            "items": { "type": "string" }
          },
          "produces": { 
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["name", "target_repo", "requires", "produces"]
      }
    }
  },
  "required": ["manifest_id", "pipeline_steps"]
}